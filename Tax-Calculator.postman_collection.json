{
  "info": {
    "_postman_id": "4b46437c-2cc7-4c35-b5f3-4c6ea826e06b",
    "name": "Beleqet API - The Vault Tax Calculator",
    "description": "Postman collection for The Vault Tax Calculator.\n\nThe endpoint accepts annual gross income as an integer in the currency's smallest unit:\n- ETB: Santim (120,000.00 ETB = 12,000,000 Santim)\n- USD: cents ($50,000.00 = 5,000,000 cents)\n\nSupported jurisdictions: ET and US.\n\nThe requests in this collection cover successful calculations, boundary values, localization, and validation failures.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Successful Calculations",
      "description": "Valid tax calculation requests for supported jurisdictions.",
      "item": [
        {
          "name": "Calculate Ethiopia Tax - 120,000 ETB",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Returns the expected ET calculation\", function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.grossIncome).to.eql(12000000);",
                  "  pm.expect(json.taxAmount).to.eql(2454000);",
                  "  pm.expect(json.netIncome).to.eql(9546000);",
                  "  pm.expect(json.currency).to.eql(\"ETB\");",
                  "  pm.expect(json.countryCode).to.eql(\"ET\");",
                  "  pm.expect(json.effectiveTaxRate).to.eql(0.2045);",
                  "});",
                  "",
                  "pm.test(\"Gross minus tax equals net\", function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.grossIncome - json.taxAmount).to.eql(json.netIncome);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept-Language",
                "value": "en",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grossIncome\": 12000000,\n  \"currency\": \"ETB\",\n  \"countryCode\": \"ET\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "localhost:4000/api/v1/tax-calculator/calculate",
              "host": [
                "localhost:4000"
              ],
              "path": [
                "api",
                "v1",
                "tax-calculator",
                "calculate"
              ]
            },
            "description": "Calculates progressive Ethiopian tax for 120,000.00 ETB annual gross income. The request sends 12,000,000 Santim."
          },
          "response": []
        },
        {
          "name": "Calculate United States Tax - $50,000",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Returns the expected US calculation\", function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.grossIncome).to.eql(5000000);",
                  "  pm.expect(json.taxAmount).to.eql(400950);",
                  "  pm.expect(json.netIncome).to.eql(4599050);",
                  "  pm.expect(json.currency).to.eql(\"USD\");",
                  "  pm.expect(json.countryCode).to.eql(\"US\");",
                  "  pm.expect(json.effectiveTaxRate).to.eql(0.08019);",
                  "});",
                  "",
                  "pm.test(\"Gross minus tax equals net\", function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.grossIncome - json.taxAmount).to.eql(json.netIncome);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept-Language",
                "value": "en",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grossIncome\": 5000000,\n  \"currency\": \"USD\",\n  \"countryCode\": \"US\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "localhost:4000/api/v1/tax-calculator/calculate",
              "host": [
                "localhost:4000"
              ],
              "path": [
                "api",
                "v1",
                "tax-calculator",
                "calculate"
              ]
            },
            "description": "Calculates progressive US federal tax for $50,000.00 annual gross income. The request sends 5,000,000 cents."
          },
          "response": []
        }
      ]
